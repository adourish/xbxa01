<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.xbxa01.glassesvr"
    android:versionCode="1"
    android:versionName="0.1.0">

    <!-- min/target SDK (31/34) come from Unity PlayerSettings and are injected into
         build.gradle; declaring <uses-sdk> here conflicts with the merger, so don't. -->

    <!-- Required for SensorManager rotation vector -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="true" />
    <uses-feature android:name="android.hardware.sensor.gyroscope"     android:required="true" />
    <uses-feature android:name="android.hardware.sensor.compass"       android:required="false" />

    <!-- Screen orientation locked to landscape for 1920×1080 glasses output -->
    <uses-feature android:name="android.hardware.screen.landscape" android:required="true" />

    <!-- ScreenCaptureService (MediaProjection fallback, SPEC §Known limits): a
         foreground service is required to hold the projection grant on Android 10+,
         and the mediaProjection service type + this permission are required on
         Android 14+ (see ScreenCaptureService's class comment). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Android 11+ package visibility: needed so AppWindow's VirtualAppWindow can
         resolve another app's launch intent (getLaunchIntentForPackage). Without this,
         other packages are invisible and launching them silently fails. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- No <application>-level android attributes: the Unity-generated launcher
         manifest is higher priority and already supplies label/icon/theme from
         PlayerSettings. Declaring them here (a library manifest) only produces
         colliding-attribute merger errors. Window-level settings we DO care about
         (fullscreen theme) go on the activity below, which is ours alone. -->
    <application>

        <activity
            android:name="com.unity3d.player.UnityPlayerActivity"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:screenOrientation="landscape"
            android:launchMode="singleTask"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:resizeableActivity="false"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Tell Android we handle display changes ourselves (no restart) -->
            <meta-data android:name="unityplayer.ForwardNativeEventsToDalvik" android:value="true" />
        </activity>

        <!-- MediaProjection fallback (SPEC §Known limits): translucent activity that
             owns the one-time screen-capture consent dialog. Not launchable from the
             launcher; only started internally via ScreenCaptureBridge.requestPermission. -->
        <activity
            android:name="com.xbxa01.appwindow.MediaProjectionRequestActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false" />

        <service
            android:name="com.xbxa01.appwindow.ScreenCaptureService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

    </application>

</manifest>
